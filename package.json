{
  "name": "auto-daily-report2",
  "version": "1.0.2",
  "description": "Electron-based Windows desktop app scaffold with HTML and CSS entry points.",
  "main": "main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "release": "electron-builder --win --publish always"
  },
  "devDependencies": {
    "electron": "^36.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.autodailyreport2.app",
    "productName": "AutoDailyReport2",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "sungman5",
      "repo": "autoDailyReport2",
      "releaseType": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "auto-daily-report2-setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AutoDailyReport2"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
